generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Authenticated DocPulse account.
/// One User has one GitHub OAuth identity and may own many Installations.
///
/// OAuth access tokens are intentionally NOT stored here.
/// GitHub OAuth exists only to authenticate a user into DocPulse.
/// All GitHub API operations use App JWTs or Installation Access Tokens.
model User {
  id              String         @id @default(uuid())
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  githubId        Int            @unique @map("github_id")
  githubLogin     String         @map("github_login")
  githubAvatarUrl String?        @map("github_avatar_url")
  email           String?
  displayName     String?        @map("display_name")
  settings        Json           @default("{}")
  installations   Installation[]
  notifications   Notification[]
  repositories    Repository[]
  workflowRuns    WorkflowRun[]

  @@map("users")
}

/// GitHub App installation record.
/// One User may have installations across multiple GitHub organisations/accounts.
model Installation {
  id             String       @id @default(uuid())
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  installationId Int          @unique @map("installation_id")
  accountLogin   String       @map("account_login")
  accountType    String       @map("account_type")
  isActive       Boolean      @default(true) @map("is_active")
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories   Repository[]

  @@map("installations")
}

/// Connected GitHub repository with documentation configuration.
model Repository {
  id               String        @id @default(uuid())
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  githubRepositoryId Int         @unique @map("github_repository_id")
  installationId   String        @map("installation_id")
  repositoryOwner  String        @map("repository_owner")
  name             String        @map("name")
  fullName         String        @map("full_name")
  defaultBranch    String        @default("main") @map("default_branch")
  private          Boolean       @default(false) @map("private")
  description      String?       @map("description")
  language         String?       @map("language")
  cloneUrl         String        @map("clone_url")
  htmlUrl          String        @map("html_url")
  visibility       String        @map("visibility")
  isActive         Boolean       @default(true) @map("is_active")
  lastSyncedAt     DateTime?     @map("last_synced_at")
  docPaths         String[]      @default([]) @map("doc_paths")
  webhookId        Int?          @map("webhook_id")
  isWebhookActive  Boolean       @default(false) @map("is_webhook_active")
  ownerId          String        @map("owner_id")
  installation     Installation  @relation(fields: [installationId], references: [id])
  owner            User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workflowRuns     WorkflowRun[]
  webhookEvents    WebhookEvent[]

  @@index([githubRepositoryId])
  @@index([installationId])
  @@index([ownerId])
  @@index([isActive])
  @@map("repositories")
}

/// Single pipeline execution triggered by one GitHub push webhook.
/// System of record for all pipeline visibility in the dashboard.
model WorkflowRun {
  id                String         @id @default(uuid())
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  status            RunStatus      @default(QUEUED)
  correlationId     String         @unique @map("correlation_id")
  webhookDeliveryId String         @unique @map("webhook_delivery_id")
  commitSha         String         @map("commit_sha")
  branch            String
  commitMessage     String?        @map("commit_message")
  startedAt         DateTime?      @map("started_at")
  completedAt       DateTime?      @map("completed_at")
  errorMessage      String?        @map("error_message")
  repositoryId      String         @map("repository_id")
  triggeredById     String?        @map("triggered_by_id")

  // Checkpoint persistence & recovery fields
  version           Int            @default(1)
  currentNode       String?        @map("current_node")
  currentStage      WorkflowStage? @map("current_stage")
  checkpointSnapshot Json?         @map("checkpoint_snapshot")
  nodeRetries       Json           @default("{}") @map("node_retries")
  lastError         Json?          @map("last_error")
  executionMetadata Json           @default("{}") @map("execution_metadata")

  notifications     Notification[]
  pullRequest       PullRequest?
  currentReviewId   String?        @map("current_review_id")
  currentReview     Review?        @relation("CurrentReview", fields: [currentReviewId], references: [id])
  reviews           Review[]       @relation("RunReviews")
  repository        Repository     @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  triggeredBy       User?          @relation(fields: [triggeredById], references: [id])

  @@map("workflow_runs")
}

/// Human review record.
/// Created by the Review Coordinator when it routes to 'needs_review'.
model Review {
  id            String       @id @default(uuid())
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  status        ReviewStatus @default(PENDING)
  comment       String?
  metrics       Json?
  reviewedAt    DateTime?    @map("reviewed_at")
  workflowRunId String       @map("workflow_run_id")
  workflowRun   WorkflowRun  @relation("RunReviews", fields: [workflowRunId], references: [id], onDelete: Cascade)

  // Back-reference for WorkflowRun.currentReview relation
  currentReviewFor WorkflowRun[] @relation("CurrentReview")

  @@map("reviews")
}

/// GitHub pull request created by the pull-requests module.
model PullRequest {
  id             String      @id @default(uuid())
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  githubPrNumber Int?        @map("github_pr_number")
  githubPrUrl    String?     @map("github_pr_url")
  title          String
  body           String?
  headBranch     String      @map("head_branch")
  baseBranch     String      @map("base_branch")
  isMerged       Boolean     @default(false) @map("is_merged")
  mergedAt       DateTime?   @map("merged_at")
  workflowRunId  String      @unique @map("workflow_run_id")
  workflowRun    WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@map("pull_requests")
}

/// In-app notification record.
/// Covers events: review.required, run.rejected, pull-request.created, run.failed, run.completed.
model Notification {
  id            String             @id @default(uuid())
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  type          String
  title         String
  message       String?
  status        NotificationStatus @default(UNREAD)
  readAt        DateTime?          @map("read_at")
  linkUrl       String?            @map("link_url")
  userId        String             @map("user_id")
  workflowRunId String?            @map("workflow_run_id")
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowRun   WorkflowRun?       @relation(fields: [workflowRunId], references: [id])

  @@map("notifications")
}

/// Pipeline overall lifecycle status.
/// We rely on a manual PostgreSQL partial unique index unique_pending_review_per_run
/// on the reviews table to enforce no more than one PENDING review per run.
enum RunStatus {
  QUEUED
  RUNNING
  CHECKPOINTED
  COMPLETED
  FAILED
  CANCELLED
  WAITING_FOR_REVIEW
}

/// Pipeline granular execution stage.
enum WorkflowStage {
  CLONING
  ANALYZING
  LOCATING_DOCUMENTATION
  WRITING
  REVIEWING
  COMMITTING
  PUSHING
  CREATING_PULL_REQUEST
  FINISHED
}

/// Human review decision states.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

/// Notification delivery states.
enum NotificationStatus {
  UNREAD
  READ
}

/// Webhook event processing status.
enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

/// Incoming GitHub webhook event persisted for audit and debugging.
model WebhookEvent {
  id               String            @id @default(uuid())
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  githubDeliveryId String            @unique @map("github_delivery_id")
  eventType        String            @map("event_type")
  action           String?
  repositoryId     String?           @map("repository_id")
  payload          Json
  receivedAt       DateTime          @default(now()) @map("received_at")
  processedAt      DateTime?         @map("processed_at")
  status           WebhookEventStatus @default(RECEIVED)
  repository       Repository?       @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([githubDeliveryId])
  @@index([eventType])
  @@index([status])
  @@index([repositoryId])
  @@map("webhook_events")
}
