{
  "extends": "@docpulse/shared-config/typescript/node.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "noEmit": false,
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": [
    "test/unit/branch-strategy.spec.ts",
    "test/unit/documentation-directory.spec.ts",
    "test/unit/source-code-analysis.spec.ts"
  ],
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/shared-utils" }
  ]
}
