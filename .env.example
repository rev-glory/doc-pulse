# =============================================================================
# DocPulse — Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in the values:
#
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This file (.env.example) IS committed — update it when adding new variables.
# =============================================================================


# =============================================================================
# PostgreSQL
# =============================================================================

# Credentials used by the Docker Compose postgres service AND the application.
POSTGRES_USER=docpulse
POSTGRES_PASSWORD=docpulse_dev_password
POSTGRES_DB=docpulse_dev

# Port exposed on the host machine (default: 5432).
POSTGRES_PORT=5432

# Full connection URL consumed by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL=postgresql://docpulse:docpulse_dev_password@localhost:5432/docpulse_dev?schema=public


# =============================================================================
# Redis
# =============================================================================

# Password for the Redis server (enforced even in dev — mirrors production).
REDIS_PASSWORD=docpulse_dev_password

# Port exposed on the host machine (default: 6379).
REDIS_PORT=6379

# Maximum memory Redis may use before evicting keys (LRU policy).
REDIS_MAX_MEMORY=256mb

# Full connection URL consumed by BullMQ and LangGraph checkpoints.
# Format: redis://:<password>@<host>:<port>
REDIS_URL=redis://:docpulse_dev_password@localhost:6379


# =============================================================================
# Backend — NestJS API (apps/backend)
# =============================================================================

# Port the NestJS HTTP server listens on.
PORT=3001

# CORS origin allowed for the frontend.
FRONTEND_URL=http://localhost:3000

# Used by the frontend to know where the API lives.
BACKEND_URL=http://localhost:3001


# =============================================================================
# JWT
# =============================================================================

# Secrets used to sign and verify JWTs. Must be at least 32 characters each.
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_at_least_32_chars

# Access token lifetime (e.g. 15m, 1h). Keep short in production.
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime (e.g. 7d, 30d).
JWT_REFRESH_EXPIRES_IN=7d


# =============================================================================
# GitHub Integration
# =============================================================================

# GitHub App ID from https://github.com/settings/apps/<your-app>
GITHUB_APP_ID=your_github_app_id

# GitHub App private key (PEM format, base64-encoded for env safety).
# Generate with: openssl genrsa | base64 -w 0
GITHUB_PRIVATE_KEY_BASE64=your_base64_encoded_private_key

# Webhook secret configured in your GitHub App settings.
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# GitHub OAuth App credentials (for user login flow).
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret


# =============================================================================
# AI — OpenAI
# =============================================================================

# OpenAI API key consumed by LangGraph agents.
OPENAI_API_KEY=sk-your_openai_api_key

# Model to use for all agent calls (override per-agent if needed).
OPENAI_MODEL=gpt-4o

# Sampling temperature (0.0 = deterministic, 2.0 = very random). Default: 0.2
OPENAI_TEMPERATURE=0.2


# =============================================================================
# AI — Anthropic (optional fallback provider)
# =============================================================================

# Leave blank to disable Anthropic. The workflow will use OpenAI only.
ANTHROPIC_API_KEY=

# Claude model to use when Anthropic is enabled.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022


# =============================================================================
# Queue (BullMQ)
# =============================================================================

# Number of jobs processed concurrently per worker instance.
QUEUE_CONCURRENCY=5

# Maximum number of automatic retries before a job is moved to the DLQ.
QUEUE_MAX_RETRIES=3

# Delay in milliseconds between retry attempts (exponential backoff applied by BullMQ).
QUEUE_RETRY_DELAY_MS=5000


# =============================================================================
# Email / Notifications (optional — leave blank to disable)
# =============================================================================

# SMTP server host (e.g. smtp.sendgrid.net, smtp.mailgun.org).
SMTP_HOST=

# SMTP port. 587 = STARTTLS (recommended), 465 = SSL/TLS, 25 = plain (not recommended).
SMTP_PORT=587

# SMTP authentication credentials.
SMTP_USER=
SMTP_PASS=

# Sender address shown in the From: header.
SMTP_FROM=DocPulse <noreply@example.com>


# =============================================================================
# Logging
# =============================================================================

# NestJS log level: error | warn | log | debug | verbose
# Use 'debug' locally, 'warn' or 'error' in production.
LOG_LEVEL=log


# =============================================================================
# Node Runtime
# =============================================================================

# Set to 'production' when running in a deployed environment.
NODE_ENV=development
