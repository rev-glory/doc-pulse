# =============================================================================
# DocPulse — Environment Variables Example
# =============================================================================
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# NEVER commit the actual .env file to version control.
# This file (.env.example) IS committed — update it when adding new variables.
# Note: CI secrets (for production deployment) are supplied via GitHub Secrets.
# =============================================================================

# =============================================================================
# Database
# =============================================================================

# Docker infrastructure settings (used by docker-compose postgres service)
POSTGRES_USER=docpulse
POSTGRES_PASSWORD=docpulse_dev_password
POSTGRES_DB=docpulse_dev
POSTGRES_PORT=5432

# Application settings
# Full connection URL consumed by Prisma Client.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL=postgresql://docpulse:docpulse_dev_password@localhost:5432/docpulse_dev?schema=public

# =============================================================================
# Redis
# =============================================================================

# Docker infrastructure settings (used by docker-compose redis service command)
REDIS_PASSWORD=docpulse_dev_password
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# Application settings
# Connection URL consumed by BullMQ and LangGraph checkpoints.
# Format: redis://:<password>@<host>:<port>
REDIS_URL=redis://:docpulse_dev_password@localhost:6379

# =============================================================================
# JWT
# =============================================================================

# Secrets used to sign and verify JWTs. Must be at least 32 characters each.
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret_at_least_32_chars

# Access/Refresh token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# GitHub
# =============================================================================

# GitHub App Integration Settings
GITHUB_APP_ID=your_github_app_id
# GitHub App private key in base64 format (base64-encoded to protect multiline PEM structure in env)
# Generate with: cat private-key.pem | base64 -w 0
GITHUB_PRIVATE_KEY_BASE64=your_base64_encoded_private_key
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# GitHub OAuth Settings (for user authentication flow)
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# =============================================================================
# LLM
# =============================================================================

# Default LLM provider choice (gemini | openai | anthropic)
DEFAULT_LLM_PROVIDER=gemini

# Google Gemini (Primary LLM Provider)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TEMPERATURE=0.2

# OpenAI (Optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# Anthropic (Optional fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# =============================================================================
# Queue
# =============================================================================

# Queue Concurrency & Retry Settings
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000

# Advanced retry policy configurations (validated by env.validation.ts)
QUEUE_BACKOFF_TYPE=exponential
QUEUE_BACKOFF_MULTIPLIER=2
QUEUE_RETRY_JITTER=0.2

# Queue maintenance settings
QUEUE_STALLED_INTERVAL_MS=30000
QUEUE_MAX_STALLED_COUNT=1
QUEUE_REMOVE_ON_COMPLETE_COUNT=100
QUEUE_REMOVE_ON_FAIL_COUNT=500

# Queue rate limits (optional, leave blank or unset to disable)
QUEUE_RATE_LIMIT_MAX=
QUEUE_RATE_LIMIT_DURATION_MS=1000

# =============================================================================
# Storage
# =============================================================================

# Directory configurations for storage (cloned repositories, artifacts)
STORAGE_ROOT=./storage
CLONES_DIR=clones
WORKSPACE_DIR=workspace
ARTIFACTS_DIR=artifacts

# Workspace retention period (in milliseconds). Default: 24h
WORKSPACE_RETENTION_PERIOD_MS=86400000

# =============================================================================
# Node Runtime & Application Settings
# =============================================================================

# Node execution context (development | production | test)
NODE_ENV=development

# Port the NestJS API server listens on
PORT=3001

# Cross-Origin Resource Sharing (CORS) links
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# NestJS Logger output verbosity (error | warn | log | debug | verbose)
LOG_LEVEL=log

# Minimum score (0-100) required to merge documentation draft pull requests
WORKFLOW_MIN_DOC_SCORE=80

# =============================================================================
# Email / Notifications (Optional - leave blank if unused)
# =============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DocPulse <noreply@example.com>

# =============================================================================
# Frontend Settings (Next.js Application)
# =============================================================================

# Base HTTP URL pointing to backend API (baked in at frontend build time)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Base WebSocket URL for progress updates (baked in at frontend build time)
NEXT_PUBLIC_WS_URL=http://localhost:3001
